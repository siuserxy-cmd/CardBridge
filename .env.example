# 服务器配置
PORT=3000
NODE_ENV=development

# 公网域名与 Cloudflare Tunnel
DOMAIN=api.xxx.com
CF_TUNNEL_TOKEN=

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 数据加密密钥（用于加密 ChatGPT Token 等敏感数据，建议 32 位以上随机字符串）
# 不配置时会回退到 JWT_SECRET，建议独立配置
APP_ENCRYPTION_KEY=your-strong-random-encryption-key-min-32-chars

# 网站公网地址（用于生成 sitemap 和邮件链接）
APP_URL=https://your-domain.com

# 数据库路径
DATABASE_PATH=./database/shop.db

# Neon PostgreSQL
NEON_HOST=
NEON_PORT=5432
NEON_DB=
NEON_USER=
NEON_PASS=

# Upstash Redis
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASS=

# ====== 手动收款配置（个人收款码）======
# 收款码图片路径（放在 public/images/ 下，支持 png/jpg/svg）
WECHAT_PAY_QR=/images/wechat-pay.jpg
ALIPAY_PAY_QR=/images/alipay-pay.jpg
# 联系客服信息（显示在支付页面）
CONTACT_INFO=如有问题请联系客服微信: your_wechat_id

# ====== 支付宝 SDK（需要企业资质，个人用户可忽略）======
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=alipay_public_key
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# ====== 微信支付 SDK（需要企业资质，个人用户可忽略）======
WECHAT_APPID=your_wechat_appid
WECHAT_MCHID=your_merchant_id
WECHAT_PRIVATE_KEY=your_wechat_private_key
WECHAT_SERIAL_NO=your_certificate_serial_number
WECHAT_APIV3_KEY=your_apiv3_key

# ====== ifaka 自动充值（ChatGPT Plus CDK 充值）======
# CDK 从 ifaka.vip 批量购买后导入到卡密库存
# API 不需要 Key，CDK 本身就是鉴权凭证
# ifaka API 地址（一般不用改）
IFAKA_API_BASE=https://ifaka.vip/api

# 管理员初始密码（启动后请立即修改）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456

# 订单预占超时（分钟，默认 30）
# ORDER_RESERVATION_MINUTES=30

# 手动确认超时（分钟，默认 720 即 12 小时）
# MANUAL_CONFIRM_MINUTES=720

# 邮件配置（购买成功后自动发卡密到买家邮箱）
EMAIL_SERVICE=QQ           # QQ / 163 / Gmail（留空用自定义SMTP）
EMAIL_USER=your_email@qq.com
EMAIL_PASS=your_auth_code  # QQ邮箱授权码（非登录密码）
EMAIL_FROM_NAME=数字商店
SHOP_NAME=数字商店
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=465
# EMAIL_SECURE=true

# ============================================
# 网站统计（51.la 免费统计，可选）
# ============================================
# 注册 https://www.51.la 后创建站点，将站点 ID 填入
ANALYTICS_51LA_ID=
