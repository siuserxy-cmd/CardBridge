# 服务器配置
PORT=3000
NODE_ENV=development

# 公网域名与 Cloudflare Tunnel
DOMAIN=api.xxx.com
CF_TUNNEL_TOKEN=

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 数据库路径
DATABASE_PATH=./database/shop.db

# Neon PostgreSQL
NEON_HOST=
NEON_PORT=5432
NEON_DB=
NEON_USER=
NEON_PASS=

# Upstash Redis
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASS=

# 支付宝配置（需要企业资质申请）
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=alipay_public_key
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 微信支付配置（需要企业资质申请）
WECHAT_APPID=your_wechat_appid
WECHAT_MCHID=your_merchant_id
WECHAT_PRIVATE_KEY=your_wechat_private_key
WECHAT_SERIAL_NO=your_certificate_serial_number
WECHAT_APIV3_KEY=your_apiv3_key

# 管理员初始密码
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456

# 邮件配置（购买成功后自动发卡密到买家邮箱）
EMAIL_SERVICE=QQ           # QQ / 163 / Gmail（留空用自定义SMTP）
EMAIL_USER=your_email@qq.com
EMAIL_PASS=your_auth_code  # QQ邮箱授权码（非登录密码）
EMAIL_FROM_NAME=数字商店
SHOP_NAME=数字商店
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
